#!/usr/bin/env bash
set -eu

PREFIX="${PREFIX:-/usr}"
LIBDIR="$PREFIX/lib/vpm"
BINDIR="$PREFIX/bin"
ETCDIR="/etc"

# ====== CHECK ======
[ "$(id -u)" -ne 0 ] && {
    echo "[ERR] Run as root"
    exit 1
}

command -v xbps-install >/dev/null || {
    echo "[ERR] xbps not found"
    exit 1
}

echo "[*] Installing VPM..."

# ====== CREATE DIR ======
install -dm755 "$LIBDIR"
install -dm755 "$LIBDIR/lib"
install -dm755 "$LIBDIR/commands"

# ====== INSTALL CORE ======
install -m755 vpm "$BINDIR/vpm"

install -m644 lib/core.sh "$LIBDIR/lib/core.sh"
install -m644 lib/ui.sh   "$LIBDIR/lib/ui.sh"

# ====== INSTALL COMMANDS ======
for cmd in install remove search update upgrade; do
    install -m755 "commands/$cmd.sh" "$LIBDIR/commands/$cmd.sh"
done

# ====== CONFIG ======
if [ ! -f "$ETCDIR/vpm.conf" ]; then
    cat > "$ETCDIR/vpm.conf" <<EOF
# VPM Config

# XBPS flags
XBPS_FLAGS="-y"

# Enable colors
COLOR=1
EOF
    echo "[*] Created /etc/vpm.conf"
fi

# ====== PERMISSIONS ======
chmod 755 "$BINDIR/vpm"

# ====== DONE ======
echo "[OK] VPM installed"
echo "[*] Binary: $BINDIR/vpm"
echo "[*] Lib:    $LIBDIR"
echo "[*] Config: $ETCDIR/vpm.conf"
